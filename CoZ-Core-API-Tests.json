{
    "info": {
        "name": "CoZ-Core API Tests",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "adminEmail",
            "value": "admin@example.com",
            "type": "string"
        },
        {
            "key": "adminPassword",
            "value": "Admin123!",
            "type": "string"
        },
        {
            "key": "accessToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "productSlug",
            "value": "",
            "type": "string"
        },
        {
            "key": "productId",
            "value": "",
            "type": "string"
        },
        {
            "key": "variantId",
            "value": "",
            "type": "string"
        },
        {
            "key": "reviewId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Admin Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    pm.environment.set('accessToken', response.accessToken);",
                                    "    console.log('Token set:', response.accessToken);",
                                    "}"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Upload",
            "item": [
                {
                    "name": "Upload Single Image",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "image",
                                    "type": "file",
                                    "src": "/path/to/your/test-image.jpg"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/upload/image",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "upload",
                                "image"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Response has url and publicId', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json.data).to.have.property('url');",
                                    "    pm.expect(json.data).to.have.property('publicId');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Upload Multiple Images",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "images",
                                    "type": "file",
                                    "src": "/path/to/image1.jpg"
                                },
                                {
                                    "key": "images",
                                    "type": "file",
                                    "src": "/path/to/image2.jpg"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/upload/images",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "upload",
                                "images"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code 200 or partial 500', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Products (Admin)",
            "item": [
                {
                    "name": "Create Product",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Test Product\",\n  \"productType\": \"T-SHIRTS\",\n  \"collection\": \"SUMMER\",\n  \"features\": [\"Soft\", \"Breathable\"],\n  \"price\": 29.99,\n  \"compareAtPrice\": 49.99,\n  \"sizeFit\": {\n    \"fitType\": \"Regular Fit\",\n    \"modelHeight\": 180,\n    \"wearingSize\": \"M\"\n  },\n  \"variants\": [\n    {\n      \"colorName\": \"Red\",\n      \"images\": [\n        { \"url\": \"https://res.cloudinary.com/demo/image/upload/sample.jpg\", \"publicId\": \"sample-red\" }\n      ],\n      \"sizes\": [\n        { \"size\": \"S\", \"stock\": 5 },\n        { \"size\": \"M\", \"stock\": 10 }\n      ]\n    }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 201', () => pm.response.to.have.status(201));",
                                    "const json = pm.response.json();",
                                    "pm.environment.set('productSlug', json.data.slug);",
                                    "pm.environment.set('productId', json.data._id);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Product by Slug",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products/slug/{{productSlug}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products",
                                "slug",
                                "{{productSlug}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Update Product (Price only)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"price\": 24.99\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products/slug/{{productSlug}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products",
                                "slug",
                                "{{productSlug}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Delete Product",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products/slug/{{productSlug}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products",
                                "slug",
                                "{{productSlug}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Low Stock Products (threshold=5)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products/low-stock?threshold=5",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products",
                                "low-stock"
                            ],
                            "query": [
                                {
                                    "key": "threshold",
                                    "value": "5"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Out of Stock Products",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products/out-of-stock",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products",
                                "out-of-stock"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Variants (Admin)",
            "item": [
                {
                    "name": "Add Variant to Product",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"colorName\": \"Blue\",\n  \"images\": [\n    { \"url\": \"https://res.cloudinary.com/demo/image/upload/sample.jpg\", \"publicId\": \"sample-blue\" }\n  ],\n  \"sizes\": [\n    { \"size\": \"L\", \"stock\": 3 },\n    { \"size\": \"XL\", \"stock\": 2 }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/products/{{productId}}/variants",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "products",
                                "{{productId}}",
                                "variants"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 201', () => pm.response.to.have.status(201));",
                                    "const json = pm.response.json();",
                                    "pm.environment.set('variantId', json.data._id);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Update Variant (change colorName)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"colorName\": \"Navy Blue\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/variants/{{variantId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "variants",
                                "{{variantId}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Update Variant Size Stock",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"stock\": 50\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/variants/{{variantId}}/sizes/L",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "variants",
                                "{{variantId}}",
                                "sizes",
                                "L"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Delete Variant",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/variants/{{variantId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "variants",
                                "{{variantId}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Reviews (Public & Admin)",
            "item": [
                {
                    "name": "Write a Review (as guest)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"content\": \"Amazing product!\",\n  \"rating\": 5,\n  \"guestName\": \"Test User\",\n  \"guestEmail\": \"test@example.com\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/reviews/product/{{productId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "reviews",
                                "product",
                                "{{productId}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 201', () => pm.response.to.have.status(201));",
                                    "const json = pm.response.json();",
                                    "pm.environment.set('reviewId', json.data._id);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Product Reviews (approved only)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/reviews/product/{{productId}}?page=1&limit=10",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "reviews",
                                "product",
                                "{{productId}}"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                }
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Admin - Approve Review",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"approved\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/reviews/{{reviewId}}/status",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "reviews",
                                "{{reviewId}}",
                                "status"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Admin - Reject Review",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"rejected\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/reviews/{{reviewId}}/status",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "reviews",
                                "{{reviewId}}",
                                "status"
                            ]
                        }
                    }
                },
                {
                    "name": "Admin - Delete Review",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/reviews/{{reviewId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "reviews",
                                "{{reviewId}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ]
}